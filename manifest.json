{
  "manifest_version": 3,
  "name": "YouTube Sub Blur",
  "version": "1.3.0",
  "description": "Blur hard subtitles on YouTube videos for language immersion",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:7331/*",
    "http://127.0.0.1:8765/*"
  ],
  "commands": {
    "toggle-blur": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Toggle subtitle blur overlay"
    },
    "review-loop": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Review loop: rewind and check subtitles"
    },
    "mine-subtitle": {
      "suggested_key": {
        "default": "Alt+M"
      },
      "description": "Extract subtitle text with OCR"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
